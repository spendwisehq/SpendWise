# blockchain/.env.example — copy to .env and fill in your values

# Polygon Amoy testnet RPC
POLYGON_MUMBAI_RPC=https://rpc-amoy.polygon.technology

# Polygon mainnet RPC
POLYGON_MAINNET_RPC=https://polygon-rpc.com

# Deployer wallet private key (never commit the real key)
DEPLOYER_PRIVATE_KEY=0x_your_deployer_wallet_private_key

# PolygonScan API key for contract verification
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Set to "true" to enable gas usage reporting
REPORT_GAS=false
