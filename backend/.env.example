# backend/.env.example — copy to .env and fill in your values

#─────────────────────────────────────
# SERVER
#─────────────────────────────────────
PORT=5000
NODE_ENV=development

#─────────────────────────────────────
# EMAIL (SMTP)
#─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

#─────────────────────────────────────
# MONGODB
#─────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017
MONGODB_NAME=spendwise

# Atlas (production):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net
# MONGODB_NAME=spendwise_db

#─────────────────────────────────────
# JWT
#─────────────────────────────────────
JWT_SECRET=your_minimum_32_char_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_minimum_32_char_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

#─────────────────────────────────────
# GROQ AI
#─────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2048

#─────────────────────────────────────
# FRONTEND
#─────────────────────────────────────
FRONTEND_URL=http://localhost:5173

#─────────────────────────────────────
# RATE LIMITING
#─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

#─────────────────────────────────────
# FILE UPLOADS
#─────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

#─────────────────────────────────────
# RAZORPAY
#─────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

#─────────────────────────────────────
# BLOCKCHAIN — POLYGON
#─────────────────────────────────────
BLOCKCHAIN_ENABLED=false
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
CHAIN_ID=80002
BACKEND_SIGNER_PRIVATE_KEY=0x_your_wallet_private_key
SPENDWISE_GROUP_SETTLEMENT_CONTRACT=0x_deployed_contract_address
SPENDWISE_FINANCIAL_SCORE_CONTRACT=0x_deployed_contract_address
SPENDWISE_AUDIT_TRAIL_CONTRACT=0x_deployed_contract_address

#─────────────────────────────────────
# API PLATFORM
#─────────────────────────────────────
API_FREE_TIER_DAILY_LIMIT=100
API_STARTER_MONTHLY_LIMIT=10000
API_GROWTH_MONTHLY_LIMIT=100000

#─────────────────────────────────────
# CLOUDINARY
#─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

#─────────────────────────────────────
# MSG91 (SMS)
#─────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_WEBHOOK_SECRET=your_msg91_webhook_secret
