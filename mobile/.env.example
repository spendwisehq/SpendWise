# mobile/.env.example — copy to .env and fill in your values

# Use your machine's LAN IP, NOT localhost — phone can't reach localhost on your computer
# Find your LAN IP: ipconfig getifaddr en0 (Mac) | ip addr (Linux)
# Both phone and computer must be on the same Wi-Fi network
EXPO_PUBLIC_API_URL=http://192.168.1.X:5000/api

# Production API URL (used when building for release)
EXPO_PUBLIC_API_URL_PROD=https://api.yourdomain.com/api
